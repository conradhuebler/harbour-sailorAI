{
  "api_endpoints": {
    "openai": {
      "name": "OpenAI",
      "base_url": "https://api.openai.com/v1",
      "endpoints": {
        "chat": "/chat/completions",
        "models": "/models",
        "streaming": "/chat/completions"
      },
      "authentication": {
        "header": "Authorization",
        "prefix": "Bearer "
      },
      "features": {
        "supportsStreaming": true,
        "supportsImages": true,
        "supportsThinking": false
      },
      "defaultModels": ["gpt-4", "gpt-3.5-turbo"],
      "headers": {
        "required": ["Content-Type", "Authorization"],
        "optional": {}
      }
    },
    "anthropic": {
      "name": "Anthropic Claude",
      "base_url": "https://api.anthropic.com/v1",
      "endpoints": {
        "chat": "/messages",
        "models": "/models",
        "streaming": "/messages"
      },
      "authentication": {
        "header": "x-api-key",
        "prefix": ""
      },
      "features": {
        "supportsStreaming": true,
        "supportsImages": false,
        "supportsThinking": true
      },
      "defaultModels": ["claude-3-5-sonnet-20241022"],
      "headers": {
        "required": ["Content-Type", "x-api-key"],
        "optional": {
          "anthropic-version": "2023-06-01"
        }
      }
    },
    "gemini": {
      "name": "Google Gemini",
