        "header": "x-goog-api-key",
        "prefix": ""
      },
      "features": {
        "supportsStreaming": true,
        "supportsImages": true,
        "supportsThinking": false
      },
      "defaultModels": ["gemini-2.0-flash"],
      "headers": {
        "required": ["Content-Type", "x-goog-api-key"],
        "optional": {}
      }
    },
